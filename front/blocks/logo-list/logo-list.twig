{# Vars #}

{% def class = '' %}
{% def title = '' %}
{% def images = [] %}

{# Template #}

<div class="logo_list">
	<div v-flux="default">
		<h2 class="title" v-font="title_0" v-anim="title">
			{{ title|strip }}
		</h2>

		<div class="items">
			{% for image in images %}
				<div class="item">
					{% include 'atoms/media' with image|merge({
						class: 'image',
						fit: 'contain'
					}) %}
				</div>
			{% endfor %}
		</div>
	</div>
</div>
