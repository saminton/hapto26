#: classes/admin.php:39
#, php-format
msgid "You are changing the options for language %s"
msgstr "Vous changez les options pour la langue %s"

#: classes/admin.php:41
msgid ""
"<strong>Be careful</strong>, you are going to modify the untranslated "
"options, they will probably be used as defaults if the translation is not "
"completed."
msgstr ""
"<strong>Soyez prudent</strong>, vous allez modifier les options non "
"traduites, elles seront probablement utilisées comme valeurs par défaut si "
"la traduction n’est pas terminée."

#: classes/admin.php:44
msgid "Use the language switcher in the admin bar to change the language."
msgstr ""
"Utilisez le sélecteur de langue dans la barre d'administration pour changer "
"la langue."

#: classes/requirements.php:16
msgid "Advanced Custom Fields and Polylang are required plugins."
msgstr "Les extensions Advanced Custom Fields et Polylang sont requises."

#: classes/requirements.php:22
msgid "Advanced Custom Fields should be on version 5.6.0 or above."
msgstr "Advanced Custom Fields doit être sur la version 5.6.0 ou supérieure."

