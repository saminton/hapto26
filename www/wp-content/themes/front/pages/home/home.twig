{% extends 'layouts/layout.twig' %}
{% block content %}
	<main class="home"
		v-barba="container"
		v-barba-namespace="page"
		v-scroll="main"
		data-ancestor="{{ ancestor_id }}"
		data-id="{{ id }}">
		<div v-flux="default">
			<h1 v-font="title_1" v-anim="title">
				{{ post.title }}
			</h1>

			<a href="http://hapto26.localhost/politique-de-confidentialite/">Link</a>
		</div>

		{% include 'blocks/contact-form' with {
			margin: 'default'
		} %}

		{% include 'plugins/example' %}
	</main>
{% endblock %}
